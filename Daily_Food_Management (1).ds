				}
			}
			"Supplier"
			{
				name = "Supplier"
				type = Customer_Portal
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Receive and confirm supply orders from the canteen \n"
				ModulePermissions
				{
