 application "Daily Food Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form daily_food_entries
		{
			displayname = "Daily Food Entries"
			success message = "Daily Food Entry Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			entry_id
			(
    			type = autonumber
				displayname = "Entry ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			date_1
			(
    			type = date
				displayname = "Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			meal_type
			(
				type = picklist
				displayname = "Meal Type"
				values = {"Breakfast","Dinner","Lunch"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			food_item
			(
				type = picklist	
				displayname = "Food Item"
				values  = items.ID
    			displayformat = [name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			quantity_prepared
			(
				type = decimal
				displayname = "Quantity Prepared"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			quantity_served
			(
				type = decimal
				displayname = "Quantity Served"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			quantity_wasted
			(
				type = decimal
				displayname = "Quantity Wasted"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			remarks
			(
    			type = textarea
				displayname = "Remarks"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Entry Created","Food Prepared","Entry Rejected","Food Served","Food Wasted","Entry Finalized","Audit Pending","Audit Passed","Audit Failed","Entry Archived","Entry Reopened"}
			}
		}
		form daily_waste_summary
		{
			displayname = "Daily Waste Summary"
			success message = "Daily Waste Summary Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			date_1
			(
    			type = date
				displayname = "Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_prepared
			(
				type = decimal
				displayname = "Total Prepared"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_served
			(
				type = decimal
				displayname = "Total Served"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_wasted
			(
				type = decimal
				displayname = "Total Wasted"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			waste_percentage
			(
    			type = percentage
				displayname = "Waste Percentage"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			entry_count
			(
				type = number
				displayname = "Entry Count"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form items
		{
			displayname = "Items"
