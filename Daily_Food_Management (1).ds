				width = medium
			)
			cost
			(
				displayname = "Cost"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			supply_date
			(
    			type = date
				displayname = "Supply Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
