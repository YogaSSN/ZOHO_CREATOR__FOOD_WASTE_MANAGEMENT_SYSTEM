		form waste_alerts
		{
			displayname = "Waste Alerts"
			success message = "Waste Alert Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			entry
			(
				type = list	
				displayname = "Entry"
				values  = daily_food_entries.ID
    			displayformat = [entry_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			waste_percentage
			(
    			type = percentage
				displayname = "Waste Percentage"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			alert_sent
			(
    			type = checkbox
				displayname = "Alert Sent"
				initial value = false
	 			row = 1
	 			column = 1   
				width = medium
			)
			sent_at
			(
    			type = datetime
				displayname = "Sent At"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Alert Created","Waste Percentage Evaluated","Alert Sent","Alert Not Sent","Alert Acknowledged","Alert Rejected","Monitoring Continued","Action Taken","Alert Resolved","Action In Progress","Action Delayed","Escalate for Intervention"}
			}
		}
