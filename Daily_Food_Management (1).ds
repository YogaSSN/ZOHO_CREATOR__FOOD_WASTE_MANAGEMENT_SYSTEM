				width = medium
			)
			item_supplied
			(
				type = picklist	
				displayname = "Item Supplied"
				values  = items.ID
    			displayformat = [name]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
	 			row = 1
	 			column = 1   
				width = medium
			)
			quantity_supplied
			(
				type = decimal
				displayname = "Quantity Supplied"
				maxchar = 16
	 			row = 1
