	reports
	{
		list daily_food_entries_Report
		{
			displayName = "All Daily Food Entries"
			show all rows from daily_food_entries    
			(
				entry_id as "Entry ID"
				date_1 as "Date"
				meal_type as "Meal Type"
				food_item as "Food Item"
				quantity_prepared as "Quantity Prepared"
				quantity_served as "Quantity Served"
				quantity_wasted as "Quantity Wasted"
				remarks as "Remarks"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (meal_type == "Dinner")
				fields = [meal_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (meal_type == "Lunch")
				fields = [meal_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban daily_food_entries_by_meal_type
		{
			displayName = "Meal Types"
			show all rows from daily_food_entries    
			(
				entry_id as "Entry ID"
				date_1 as "Date"
				meal_type as "Meal Type"
				food_item as "Food Item"
				quantity_prepared as "Quantity Prepared"
				quantity_served as "Quantity Served"
				quantity_wasted as "Quantity Wasted"
				remarks as "Remarks"
			)
			options
			(
	 			display field = meal_type
	 		)
		}
		list supplier_inventory_Report
		{
			displayName = "All Supplier Inventories"
			show all rows from supplier_inventory    
			(
				supplier_name as "Supplier Name"
				item_supplied as "Item Supplied"
				quantity_supplied as "Quantity Supplied"
				cost as "Cost"
				(
					display = total,average,min,max	
				)
				supply_date as "Supply Date"
			)
		}
		list items_Report
		{
			displayName = "All Items"
			show all rows from items    
			(
				brand as "Brand"
				cost_price as "Cost Price"
				created_time as "Created Time"
				dimension_unit as "Dimension Unit"
				ean as "EAN"
				height as "Height"
				hsn_or_sac_code as "HSN Or SAC Code"
				isbn as "ISBN"
				last_modified_time as "Last Modified Time"
				length_field as "Length"
				manufacturer as "Manufacturer"
				mpn as "MPN"
				name as "Name"
				opening_stock as "Opening Stock"
				opening_stock_rate_per_unit as "Opening Stock Rate Per Unit"
				purchase_account_name as "Purchase Account Name"
				purchase_description as "Purchase Description"
				reorder_point as "Reorder Point"
				sales_account_name as "Sales Account Name"
				sales_description as "Sales Description"
				sat_item_key_code as "SAT Item Key Code"
				sat_unit_code as "SAT Unit Code"
				selling_price as "Selling Price"
				sku as "SKU"
				upc as "UPC"
				weight as "Weight"
				weight_unit as "Weight Unit"
				width as "Width"
			)
		}
		list waste_alerts_Report
		{
			displayName = "All Waste Alerts"
			show all rows from waste_alerts    
			(
				entry as "Entry"
				waste_percentage as "Waste Percentage"
				(
					display = total,average,min,max	
				)
				alert_sent as "Alert Sent"
				sent_at as "Sent At"
			)
		}
		list weekly_reports_Report
		{
			displayName = "All Weekly Reports"
			show all rows from weekly_reports    
			(
				report_week as "Report Week"
				total_waste as "Total Waste"
				total_cost_loss as "Total Cost Loss"
				(
					display = total,average,min,max	
				)
				generated_at as "Generated At"
				sent_to as "Sent To"
			)
		}
		list user_roles_Report
		{
			displayName = "All User Roles"
			show all rows from user_roles    
			(
				user_name as "User Name"
				role_type as "Role Type"
				assigned_to as "Assigned To"
			)
		}
		list daily_waste_summary_Report
		{
			displayName = "All Daily Waste Summaries"
			show all rows from daily_waste_summary    
			(
				date_1 as "Date"
				total_prepared as "Total Prepared"
				total_served as "Total Served"
				total_wasted as "Total Wasted"
				waste_percentage as "Waste Percentage"
				(
					display = total,average,min,max	
				)
				entry_count as "Entry Count"
			)
		}
	}
