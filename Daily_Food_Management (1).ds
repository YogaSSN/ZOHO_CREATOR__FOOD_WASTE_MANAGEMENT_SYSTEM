				width = medium
			)
			purchase_account_name
			(
    			type = text
				displayname = "Purchase Account Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			purchase_description
			(
    			type = textarea
				displayname = "Purchase Description"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			reorder_point
			(
				type = decimal
				displayname = "Reorder Point"
				maxchar = 16
	 			row = 1
